# ============================================
# 📋 Template de Variáveis de Ambiente
# ============================================
# COPIE ESTE ARQUIVO PARA .env E PREENCHA
# NÃO COMMITE .env COM DADOS SENSÍVEIS!
# ============================================

# ============================================
# 🗄️ Banco de Dados MySQL
# ============================================
MYSQL_ROOT_PASSWORD=seu_senha_root_aqui
MYSQL_DATABASE=ciappi
MYSQL_USER=ciappi_user
MYSQL_PASSWORD=sua_senha_usuario_aqui
DB_PORT=3309
DB_HOST=localhost

# ============================================
# 🕐 Timezone
# ============================================
TZ=America/Recife

# ============================================
# 🔐 FastAPI & Autenticação
# ============================================
SECRET_KEY=sua_chave_secreta_muito_longa_e_complexa_aqui
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================
# 🔗 Conexão Backend <-> Database
# ============================================
DATABASE_URL=mysql+pymysql://ciappi_user:sua_senha_usuario_aqui@localhost:3309/ciappi

# ============================================
# 🌐 URLs de Acesso
# ============================================
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:8501

# ============================================
# 📊 Ambiente
# ============================================
ENVIRONMENT=development
DEBUG=True

# ============================================
# 📧 Email (se necessário)
# ============================================
# SMTP_HOST=seu_smtp_host
# SMTP_PORT=587
# SMTP_USER=seu_email@example.com
# SMTP_PASSWORD=sua_senha_email

# ============================================
# 🔑 Chaves Externas (se aplicável)
# ============================================
# API_KEY_EXEMPLO=sua_chave_aqui
# EXTERNAL_API_URL=https://api.example.com

